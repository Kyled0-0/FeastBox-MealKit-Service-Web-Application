# Keep the build context small and prevent secrets from leaking into image layers.

# Deps + build outputs
node_modules
**/node_modules
dist
build
.vite
.cache

# Secrets (any depth, any suffix)
.env
.env.*
**/.env
**/.env.*

# Git / VCS
.git
.gitignore
.gitattributes
.github

# IDE / OS
.vscode
.idea
.DS_Store
Thumbs.db
*.swp
*.swo

# Local-only docs and AI artefacts (per CLAUDE.md commit rules)
CLAUDE.md
docs_foundation
docs/superpowers
.claude
.mcp.json
Plan_ORG
*.pkl
feastbox-source-dump.txt
memory
SIT226-7_2HD.md
DEMO_RUNBOOK.txt

# Tests (run on host, not in runtime image)
**/*.test.js
**/*.spec.js
**/test-utils
**/__tests__
coverage
.nyc_output
vitest.config.js

# Frontend tree (this Dockerfile builds the API only)
src
public
index.html
vite.config.js
postcss.config.js
tailwind.config.js
# Root-anchored so server/package.json is not matched.
./package.json
./package-lock.json

# Compose / infra manifests
docker-compose.yml
docker-compose.*.yml
Dockerfile
.dockerignore
k8s
