{
  "name": "my-enhanced-website",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:db": "docker compose up -d --wait db",
    "dev:migrate": "npm --prefix server run db:migrate:deploy",
    "dev:server": "npm --prefix server run dev",
    "dev:all": "npm run dev:db && npm run dev:migrate && concurrently -k -n vite,api -c cyan,magenta \"npm run dev\" \"npm run dev:server\"",
    "build": "vite build",
    "preview": "vite preview",
    "deploy": "gh-pages -d dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:server": "npm run test --prefix server",
    "test:server:auth": "npm run test:auth --prefix server",
    "test:server:security": "npm run test:security --prefix server"
  },
  "dependencies": {
    "@popperjs/core": "^2.11.8",
    "bootstrap": "^5.3.3",
    "bootstrap-icons": "^1.11.3",
    "pinia": "^2.2.2",
    "vue": "^3.4.37",
    "vue-router": "^4.4.5"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.1.2",
    "@vue/test-utils": "^2.4.9",
    "concurrently": "^9.2.1",
    "gh-pages": "^6.3.0",
    "happy-dom": "^20.9.0",
    "vite": "^5.4.1",
    "vitest": "^2.1.9"
  }
}
