# Copy this file to .env.local and fill in values for local development.
# .env.local is gitignored and must never be committed.

# Base URL of the Express API (Phase 2+). REQUIRED for `npm run dev` — the
# frontend api.js has no Vite proxy fallback, so an unset value sends API
# calls to the Vite dev server origin and `/meals` will fail.
VITE_API_URL=http://localhost:3000

# ── server/ environment variables ─────────────────────────────────────────────
# Generate JWT secrets with:
#   node -e "process.stdout.write(require('crypto').randomBytes(64).toString('hex'))"
# Run that command twice and use different values for each secret.
# Copy these into server/.env (gitignored) for local development.
# Port 5433 (not 5432): the dev compose intentionally avoids 5432 because
# Windows machines often have a native PostgreSQL service already on that port.
DATABASE_URL=postgresql://feastbox:feastbox_dev@localhost:5433/feastbox
JWT_SECRET=replace_with_64_byte_hex_string
JWT_REFRESH_SECRET=replace_with_different_64_byte_hex_string
CLIENT_URL=http://localhost:5173
PORT=3000
NODE_ENV=development
