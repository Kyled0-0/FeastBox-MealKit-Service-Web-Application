# server/.env.example — copy to server/.env and fill in real values.
# server/.env is gitignored (see server/.gitignore line 2) and is also
# referenced by docker-compose.yml via `env_file: ./server/.env` to supply
# JWT secrets without committing them to the tracked compose file.

# DATABASE_URL is intentionally dev-realistic, NOT a sentinel: these creds
# match docker-compose.yml's `db` service exactly, so a fresh `cp .env.example
# .env` produces a working local connection. WARNING: never reuse these for
# staging or production — they are checked into the public template above.
DATABASE_URL=postgresql://feastbox:feastbox_dev@localhost:5433/feastbox

# JWT secrets MUST be unique per environment and at least 32 hex characters.
# Generate each one separately with the command below (run it twice for two
# distinct values). Empty here triggers the required-env-var crash at
# server/server.js:5-8 — fail-loud is the intended behaviour.
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=
JWT_REFRESH_SECRET=

CLIENT_URL=http://localhost:5173
PORT=3000
NODE_ENV=development
